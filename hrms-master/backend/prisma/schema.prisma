generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int         @id @default(autoincrement())
  name          String
  email                  String      @unique
  password_hash          String
  resetPasswordOtp       String?
  resetPasswordOtpExpiry DateTime?
  role                   String      @default("Admin")
  branch_id     Int?
  department_id Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  branch        Branch?     @relation(fields: [branch_id], references: [id])
  department    Department? @relation(fields: [department_id], references: [id])

  employee_level_id Int?
  employee_grade_id Int?
  employeeLevel     EmployeeLevel? @relation(fields: [employee_level_id], references: [id])
  employeeGrade     EmployeeGrade? @relation(fields: [employee_grade_id], references: [id])

  shift_id Int?
  shift    Shift? @relation(fields: [shift_id], references: [id])

  adminBranchRestrictions     AdminBranchRestriction[]
  adminDepartmentRestrictions AdminDepartmentRestriction[]
  activityLogs                ActivityLog[]
  employeeGradeHistory        EmployeeGradeHistory[]
  parkingSlot                 ParkingSlot?
  attendanceRecords           AttendanceRecord[]
  attendanceRequests          AttendanceRequest[] @relation("RequestUser")
  approvedRequests            AttendanceRequest[] @relation("RequestApprover")
  
  // Visit Management
  visits                      Visit[] @relation("VisitUser")
  approved_visits             Visit[] @relation("VisitApprover")

  // New Silos for Dynamic Dashboard
  expenses                    ExpenseRequest[]
  breakLogs                   BreakLog[]
  documentRequests            DocumentRequest[] @relation("DocumentRequestUser")
  approvedDocs                DocumentRequest[] @relation("DocumentApprover")
  payrolls                    Payroll[]

  // Employee Tracking Module
  trackingConfig              TrackingConfig?
  trackingLogs                TrackingLog[]
  trackingExceptions          TrackingException[]
  dailyWorks                  DailyWork[]

  designation_id Int?
  designation    Designation? @relation(fields: [designation_id], references: [id])

  @@index([branch_id], map: "User_branch_id_fkey")
  @@index([department_id], map: "User_department_id_fkey")
  @@index([employee_level_id])
  @@index([employee_grade_id])
  @@index([shift_id])
  @@index([designation_id])
}

// ... existing models ...

model ExpenseRequest {
  id          Int      @id @default(autoincrement())
  user_id     Int
  amount      Float
  category    String   // Travel, Meal, Office, etc.
  description String?  @db.Text
  date        DateTime @db.Date
  status      String   @default("Pending") // Pending, Approved, Rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model BreakLog {
  id                   Int      @id @default(autoincrement())
  user_id              Int
  attendance_id        Int?
  start_time           DateTime @default(now())
  end_time             DateTime?
  duration_minutes     Int      @default(0)
  break_type           String   @default("Standard") // Lunch, Tea, etc.
  status               String   @default("Completed") // Ongoing, Completed
  
  user                 User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  attendance           AttendanceRecord? @relation(fields: [attendance_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model DocumentRequest {
  id             Int      @id @default(autoincrement())
  user_id        Int
  // Types: BankChange, DeviceChange, FaceChange, ProfileChange, WFH, ShortLeave, TaxDocument, ShiftChange
  request_type   String
  requested_data Json
  reason         String?  @db.Text
  status         String   @default("Pending")
  approver_id    Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User  @relation("DocumentRequestUser", fields: [user_id], references: [id], onDelete: Cascade)
  approver User? @relation("DocumentApprover", fields: [approver_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([status])
}

model Company {
  id          Int      @id @default(autoincrement())
  name        String
  code        String?  @unique
  website     String?
  logo_url    String?
  tax_info    String?
  status      String   @default("Active")
  order_index Int      @default(0)
  branches    Branch[]
}

model Zone {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  order_index Int      @default(0)
  branches    Branch[]
}

model Branch {
  id          Int          @id @default(autoincrement())
  name        String
  code        String       @unique
  type        String       @default("Metro")
  order_index Int          @default(0)
  company_id  Int?
  zone_id     Int?
  company     Company?     @relation(fields: [company_id], references: [id])
  zone        Zone?        @relation(fields: [zone_id], references: [id])
  departments Department[]
  users       User[]

  adminBranchRestrictions AdminBranchRestriction[]
  idCardTemplates         IdCardTemplate[]

  @@index([zone_id], map: "Branch_zone_id_fkey")
  @@index([company_id])
}

model Department {
  id                          Int                          @id @default(autoincrement())
  name                        String
  branch_id                   Int
  order_index                 Int                          @default(0)
  branch                      Branch                       @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  subDepartments              SubDepartment[]
  users                       User[]
  adminDepartmentRestrictions AdminDepartmentRestriction[]
  idCardTemplates             IdCardTemplate[]

  @@index([branch_id], map: "Department_branch_id_fkey")
}

model SubDepartment {
  id            Int           @id @default(autoincrement())
  name          String
  department_id Int
  order_index   Int           @default(0)
  designations  Designation[]
  department    Department    @relation(fields: [department_id], references: [id], onDelete: Cascade)

  @@unique([name, department_id])
  @@index([department_id], map: "SubDepartment_department_id_fkey")
}

model Designation {
  id                Int           @id @default(autoincrement())
  name              String
  sub_department_id Int
  order_index       Int           @default(0)
  subDepartment     SubDepartment @relation(fields: [sub_department_id], references: [id], onDelete: Cascade)
  users             User[]

  @@unique([name, sub_department_id])
  @@index([sub_department_id], map: "Designation_sub_department_id_fkey")
}

model EmployeeLevel {
  id          Int             @id @default(autoincrement())
  name        String
  parent_id   Int?
  order_index Int             @default(0)
  parent      EmployeeLevel?  @relation("EmployeeLevelHierarchy", fields: [parent_id], references: [id], onDelete: SetNull)
  children    EmployeeLevel[] @relation("EmployeeLevelHierarchy")
  users       User[]

  @@index([parent_id])
}

model EmployeeGrade {
  id      Int                    @id @default(autoincrement())
  name    String
  code    String?                @unique
  status  String                 @default("Active")
  users   User[]
  history EmployeeGradeHistory[]
}

model AdminBranchRestriction {
  id        Int    @id @default(autoincrement())
  user_id   Int
  branch_id Int
  user      User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  branch    Branch @relation(fields: [branch_id], references: [id], onDelete: Cascade)

  @@unique([user_id, branch_id])
  @@index([user_id])
  @@index([branch_id])
}

model AdminDepartmentRestriction {
  id            Int        @id @default(autoincrement())
  user_id       Int
  department_id Int
  user          User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  department    Department @relation(fields: [department_id], references: [id], onDelete: Cascade)

  @@unique([user_id, department_id])
  @@index([user_id])
  @@index([department_id])
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  action      String
  entity_type String
  entity_name String
  details     String?  @db.Text
  user_id     Int?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([createdAt])
  @@index([entity_type])
}

// ==========================================
// Phase 3 & 4 New Models
// ==========================================

model EmployeeGradeHistory {
  id             Int       @id @default(autoincrement())
  user_id        Int
  grade_id       Int
  effective_from DateTime
  effective_to   DateTime?
  remarks        String?   @db.Text
  assigned_by    Int? // User ID who assigned it
  status         String    @default("Active") // Active or Closed
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user  User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  grade EmployeeGrade @relation(fields: [grade_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([grade_id])
}

model ParkingSlot {
  id             Int      @id @default(autoincrement())
  slot_number    String   @unique
  user_id        Int?     @unique // One slot per user
  vehicle_number String?
  access_type    String   @default("QR") // "QR" or "Sticker"
  status         String   @default("Active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
}

model EmergencyNumber {
  id           Int      @id @default(autoincrement())
  contact_name String
  number       String
  type         String   @default("Medical") // "Medical", "Security", "Fire", "Other"
  status       String   @default("Active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WhatsAppAlert {
  id               Int      @id @default(autoincrement())
  alert_name       String
  trigger_event    String
  recipient_type   String   @default("Individual")
  message_template String   @db.Text
  status           String   @default("Active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model IdCardTemplate {
  id            Int      @id @default(autoincrement())
  template_name String
  template_type String   @default("Employee") // Employee, Contractor, Visitor
  branch_id     Int?
  department_id Int?
  status        String   @default("Active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch     Branch?     @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  department Department? @relation(fields: [department_id], references: [id], onDelete: SetNull)

  @@index([branch_id])
  @@index([department_id])
}

model DailyAttendanceEmail {
  id             Int      @id @default(autoincrement())
  report_name    String
  recipient_type String   @default("Manager")
  filter_value   String?
  schedule_time  String
  email_template String?  @db.Text
  status         String   @default("Active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CompanySetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// Phase 5: Attendance Models
// ==========================================

model Shift {
  id                   Int      @id @default(autoincrement())
  name                 String
  start_time           String   // HH:mm format
  end_time             String   // HH:mm format
  grace_time_minutes   Int      @default(0)
  half_day_min_hours   Float    @default(4.0)
  full_day_min_hours   Float    @default(8.0)
  break_duration_mins  Int      @default(60) // Standard break duration
  is_active            Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users User[]
}

model AttendanceRecord {
  id                  Int      @id @default(autoincrement())
  user_id             Int
  date                DateTime @db.Date // Only stores the YYYY-MM-DD
  in_time             DateTime? // Full timestamp of punch in
  out_time            DateTime? // Full timestamp of punch out
  break_minutes       Int      @default(0) // Track literal break minutes taken
  total_working_hours Float    @default(0.0)
  late_by_minutes     Int      @default(0)
  early_leaving_mins  Int      @default(0)
  overtime_hours      Float    @default(0.0)
  
  // Status: Present, Absent, Late, Half Day, Leave, WeekOff, Holiday, MissingPunch
  status              String   @default("Absent")
  
  // Source: Biometric, App, Web, Manual, Bulk
  source              String   @default("Web")
  remarks             String?  @db.Text
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  breakLogs           BreakLog[]

  @@unique([user_id, date]) // One primary record per user per day
  @@index([user_id])
  @@index([date])
  @@index([status])
}

model AttendanceRequest {
  id               Int      @id @default(autoincrement())
  user_id          Int
  // Types: MissingPunchOut, Overtime, BreakCorrection, WeekOffExchange, AttendanceModification
  request_type     String   
  // Optional linkage to a specific date/record
  date             DateTime @db.Date 
  
  // Old/Requested Values Stored as JSON or simple fields for flexibility
  requested_data   Json     // e.g. { "out_time": "18:00", ... }
  reason           String   @db.Text
  
  // Tracking
  status           String   @default("Pending") // Pending, Approved, Rejected
  approver_id      Int?
  approver_remarks String?  @db.Text
  
  createdAt        DateTime @default(now())
  modifiedAt       DateTime @updatedAt
  
  user     User  @relation("RequestUser", fields: [user_id], references: [id], onDelete: Cascade)
  approver User? @relation("RequestApprover", fields: [approver_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([approver_id])
  @@index([status])
}

model Payroll {
  id             Int      @id @default(autoincrement())
  user_id        Int
  month          Int      // 1-12
  year           Int
  basic_salary   Float
  allowances     Float    @default(0.0)
  deductions     Float    @default(0.0)
  net_salary     Float
  status         String   @default("Pending") // Pending, Processed, Released
  paid_at        DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, month, year])
  @@index([user_id])
}

// ==========================================
// Phase 6: Employee Tracking Module
// ==========================================

model Geofence {
  id            Int      @id @default(autoincrement())
  name          String
  latitude      String
  longitude     String
  radius        Int      @default(200)  // meters
  status        String   @default("Active")  // Active, Inactive
  punchRule     String   @default("inside_only")  // inside_only, outside_with_reason
  employeeCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TrackingConfig {
  id               Int      @id @default(autoincrement())
  user_id          Int      @unique
  enabled          Boolean  @default(true)
  frequency        Int      @default(15)  // minutes
  workingHoursOnly Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model TrackingLog {
  id           Int      @id @default(autoincrement())
  user_id      Int
  latitude     String
  longitude    String
  location     String?   // Readable location name
  status       String   @default("Working")  // Working, Break, Field Visit, Offline
  batteryLevel Int?
  timestamp    DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([timestamp])
  @@index([status])
}

model TrackingException {
  id          Int       @id @default(autoincrement())
  user_id     Int
  type        String    // Late Punch, Geofence Violation, GPS Off, Internet Off, Unauthorized Movement
  severity    String    @default("Medium")  // Low, Medium, High, Critical
  description String?   @db.Text
  status      String    @default("Pending")  // Pending, Approved, Rejected, Asked Reason
  reason      String?   @db.Text
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model DailyWork {
  id                  Int      @id @default(autoincrement())
  user_id             Int
  work_date           DateTime @db.Date
  check_in_time       DateTime?
  check_out_time      DateTime?
  total_work_hours    Float    @default(0.0)
  total_distance      Float    @default(0.0)
  tasks_completed     Int      @default(0)
  break_time_mins     Int      @default(0)
  work_type           String   @default("Field") // Office, Field
  status              String   @default("Pending") // Pending, Approved, Rejected, Correction Requested
  admin_remark        String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  activities          WorkActivity[]

  @@unique([user_id, work_date])
  @@index([user_id])
  @@index([work_date])
  @@index([status])
}

model WorkActivity {
  id            Int       @id @default(autoincrement())
  daily_work_id Int
  activity_time DateTime  @default(now())
  latitude      String?
  longitude     String?
  activity_type String    // Check In, Client Visit, Lunch Break, Field Visit, Check Out, etc.
  location      String?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())

  dailyWork     DailyWork @relation(fields: [daily_work_id], references: [id], onDelete: Cascade)

  @@index([daily_work_id])
}

// ==========================================
// Phase 7: Visit Management Module
// ==========================================

model Visit {
  id                   Int       @id @default(autoincrement())
  user_id              Int
  date                 DateTime  @db.Date
  client_name          String
  client_contact       String?
  company_name         String?
  city                 String?
  address              String?   @db.Text
  purpose              String?   @db.Text
  priority_level       String    @default("Medium") // High, Medium, Low
  remarks              String?   @db.Text
  
  // Status: Draft, Planned, Checked-In, Completed, Cancelled, Pending Approval
  status               String    @default("Draft")

  // Check-In Data
  check_in_time        DateTime?
  check_in_latitude    String?
  check_in_longitude   String?
  check_in_photo_url   String?

  // Check-Out Data
  check_out_time       DateTime?
  check_out_latitude   String?
  check_out_longitude  String?
  work_summary         String?   @db.Text
  next_follow_up_date  DateTime? @db.Date
  document_url         String?
  customer_signature_url String?

  // Approval Data
  approver_id          Int?
  approval_status      String? // Approved, Rejected, Reson Requested
  approval_comments    String? @db.Text

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User      @relation("VisitUser", fields: [user_id], references: [id], onDelete: Cascade)
  approver             User?     @relation("VisitApprover", fields: [approver_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([date])
  @@index([status])
}
