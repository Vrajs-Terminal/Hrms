{
    "version": 2,
    "regions": ["sin1"],
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        },
        {
            "src": "backend/src/server.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": ["backend/src/**", "backend/prisma/**"]
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/src/server.ts"
        },
        {
            "source": "/((?!api).*)",
            "destination": "/index.html"
        }
    ]
}